#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    format_tag_separator: " | ",
    browser_column_widths: [20, 38, 42],
    background_color: None,
    text_color: "#e5e2e1",
    header_background_color: None,
    modal_background_color: None,
    modal_backdrop: true,
    preview_label_style: (fg: "#c1c7ca"),
    preview_metadata_group_style: (fg: "#c6c6c7", modifiers: "Bold"),
    
    highlighted_item_style: (fg: "#c1c7ca", modifiers: "Bold"),
    current_item_style: (fg: "#2b3133", bg: "#c1c7ca", modifiers: "Bold"),
    
    // CORRECCIÓN: outline_variant -> surface_variant
    borders_style: (fg: "#434749"), 
    highlight_border_style: (fg: "#8d9193"),
    
    symbols: (
        song: "󰝚 ",
        dir: "󰉋 ",
        playlist: "󰲸 ",
        marker: "󰓎 ",
        ellipsis: "...",
        song_style: (fg: "#c6c6c7"),
        dir_style: (fg: "#c1c7ca"),
        playlist_style: (fg: "#cbc4cd"),
    ),
    level_styles: (
        info: (fg: "#c6c6c7", bg: "#131313"),
        warn: (fg: "#c1c7ca", bg: "#131313"),
        error: (fg: "#ffb4ab", bg: "#131313"),
        debug: (fg: "#e5e2e1", bg: "#131313"),
        trace: (fg: "#434749", bg: "#131313"),
    ),
    progress_bar: (
        symbols: ["█", "█", "█", " ", "█"],
        // CORRECCIÓN: surface_container_high -> surface_variant
        track_style: (fg: "#434749"),
        elapsed_style: (fg: "#c6c6c7"),
        thumb_style: (fg: "#c1c7ca"),
        use_track_when_empty: true,
    ),
    volume: (
        symbols: ["━", "━", " "],
        // CORRECCIÓN: surface_container_high -> surface_variant
        track_style: (fg: "#434749"),
        elapsed_style: (fg: "#c1c7ca"),
        thumb_style: (fg: "#c1c7ca"),
    ),
    scrollbar: (
        symbols: ["┋", "█", "󰄿", "󰄼"],
        // CORRECCIÓN: surface_container_high -> surface_variant
        track_style: (fg: "#434749"),
        ends_style: (fg: "#c1c7ca"),
        thumb_style: (fg: "#c1c7ca"),
    ),
    tab_bar: (
        active_style: (fg: "#2b3133", bg: "#c1c7ca", modifiers: "Bold"),
        inactive_style: (fg: "#c4c7c9", bg: None),
    ),
    song_table_format: [
        (
            prop: (kind: Property(Artist), style: (fg: "#c1c7ca"),
                default: (kind: Text("Unknown Artist"), style: (fg: "#c4c7c9"))
            ),
            label_prop: (kind: Text("Artist")),
            width: "20%",
        ),
        (
            prop: (kind: Property(Title), style: (fg: "#e5e2e1"),
                default: (kind: Text("Unknown Title"), style: (fg: "#e5e2e1"))
            ),
            label_prop: (kind: Text("Title")),
            width: "35%",
        ),
        (
            prop: (kind: Property(Album), style: (fg: "#c6c6c7"),
                default: (kind: Text("Unknown Album"), style: (fg: "#c4c7c9"))
            ),
            label_prop: (kind: Text("Album")),
            width: "30%",
        ),
        (
            prop: (kind: Property(Duration), style: (fg: "#e5e2e1"),
                default: (kind: Text("-"))
            ),
            label_prop: (kind: Text("Duration")),
            width: "15%",
            alignment: Right,
        ),
    ],
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "4",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "35",
                            borders: "LEFT | TOP | BOTTOM",
                            border_symbols: Inherited(parent: Rounded, bottom_left: "├"),
                            pane: Component("header_left")
                        ),
                        (
                            size: "100%",
                            borders: "ALL",
                            border_symbols: Inherited(parent: Rounded, top_left: "┬", top_right: "┬", bottom_left: "┴", bottom_right: "┴"),
                            pane: Component("header_center")
                        ),
                        (
                            size: "35",
                            borders: "RIGHT | TOP | BOTTOM",
                            border_symbols: Inherited(parent: Rounded, bottom_right: "┤"),
                            pane: Component("header_right")
                        ),
                    ]
                )
            ),
            (
                pane: Pane(Tabs),
                borders: "RIGHT | LEFT | BOTTOM",
                border_symbols: Rounded,
                size: "2",
            ),
            (
                pane: Pane(TabContent),
                size: "100%",
            ),
            (
                size: "3",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "12",
                            borders: "ALL",
                            border_symbols: Inherited(parent: Rounded, top_right: "┬", bottom_right: "┴"),
                            pane: Component("input_mode")
                        ),
                        (
                            size: "100%",
                            borders: "TOP | BOTTOM | RIGHT",
                            border_symbols: Rounded,
                            border_title: [(kind: Text(" ")), (kind: Property(Status(QueueLength()))), (kind: Text(" songs / ")), (kind: Property(Status(QueueTimeTotal()))), (kind: Text(" total time "))],
                            border_title_alignment: Right,
                            pane: Component("progress_bar_comp"),
                        ),
                    ]
                ),
            ),
        ],
    ),
    components: {
        "header_left": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Pane(Property(content: [(kind: Text("[ "), style: (fg: "#c1c7ca")), (kind: Property(Status(StateV2())), style: (fg: "#e5e2e1", modifiers: "Bold")), (kind: Text(" ]"), style: (fg: "#c1c7ca"))]))),
                (size: "1", pane: Pane(Property(content: [(kind: Property(Status(Elapsed))), (kind: Text(" / ")), (kind: Property(Status(Duration)))]))),
            ]
        ),
        "header_center": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Pane(Property(content: [(kind: Property(Song(Title)), style: (modifiers: "Bold"))], align: Center))),
                (size: "100%", pane: Pane(Property(content: [(kind: Property(Song(Artist)), style: (fg: "#c6c6c7")), (kind: Text(" - ")), (kind: Property(Song(Album)) )], align: Center))),
            ]
        ),
        "header_right": Split(
            direction: Vertical,
            panes: [
                (size: "1", pane: Split(
                    direction: Horizontal,
                    panes: [
                        (size: "100%", pane: Pane(Volume())),
                        (size: "10", pane: Pane(Property(content: [(kind: Text("󰕾 ")), (kind: Property(Status(Volume))), (kind: Text("%"))], align: Right))),
                    ]
                )),
                (size: "1", pane: Pane(Property(content: [(kind: Property(Status(Bitrate))), (kind: Text(" kbps"))], align: Right))),
            ]
        ),
        "input_mode": Pane(Property(
            content: [
                (kind: Transform(Replace(content: (kind: Property(Status(InputMode()))), replacements: [
                    (match: "Normal", replace: (kind: Text(" NORMAL "), style: (fg: "#2b3133", bg: "#c1c7ca", modifiers: "Bold"))),
                    (match: "Insert", replace: (kind: Text(" INSERT "), style: (fg: "#2f3132", bg: "#c6c6c7", modifiers: "Bold"))),
                ])))
            ], align: Center
        )),
        "progress_bar_comp": Split(
            direction: Horizontal,
            panes: [
                (size: "1", pane: Pane(Empty())),
                (size: "100%", pane: Pane(ProgressBar)),
                (size: "1", pane: Pane(Empty())),
            ]
        )
    },
)
